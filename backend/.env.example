# ==========================================
# MatchHub Backend — Environment Variables
# Copy this file to .env and fill in values
# ==========================================

# Server
SERVER_PORT=8080
SERVER_ENV=development        # development | production

# Database (MySQL 8.0)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=matchhub
DB_USER=matchhub_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD  # Only for docker-compose
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Redis
REDIS_URL=redis://localhost:6379

# JWT (RSA 4096-bit keys — generate with: make generate-keys)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h    # 7 days

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@matchhub.com
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
EMAIL_FROM=MatchHub <noreply@matchhub.com>

# Security
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX_STRING_FOR_AES256

# CORS — comma-separated list of allowed origins (no spaces around commas)
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000

# Rate limiting (requests per window)
RATE_LIMIT_REGISTER=3
RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGOUT=10

# Email verification requirement
REQUIRE_EMAIL_VERIFICATION=false

# Max upload size in bytes (default 5 MB)
MAX_UPLOAD_SIZE=5242880
